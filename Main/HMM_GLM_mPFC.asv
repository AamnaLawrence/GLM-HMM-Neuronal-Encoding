histogram(log10(abs(allW_random)+eps), edges, 'Normalization','pdf');
xline(1, 'r', 'LineWidth', 2, 'Label', '|w| = 10', ...
      'LabelHorizontalAlignment', 'left');
title('Random')
xlabel('log10(|Weight|)')
hold off
