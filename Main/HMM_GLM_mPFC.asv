sqErr_glmfit=results_glmfit.sqErr(2:end);
plot(2:numel(results_glmfit.sqErr), sqErr_glmfit, 'o-','LineWidth',2);
sqErr_random=results_random.sqErr(2:end);
plot(2:numel(results_random.sqErr), sqErr_random, 'o-','LineWidth',2);
xlabel('Iteration');
ylabel('Squared Error');
legend('Glmnet','Glmfit','Random')
