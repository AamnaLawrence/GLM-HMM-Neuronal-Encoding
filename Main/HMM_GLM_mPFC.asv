exportgraphics(gcf, 'C:\Users\Harris_Lab\OneDrive - Johns Hopkins\Johns Hopkins Neuroscience\Lab\Janak Lab\Neuropixel\Manuscript prep\GLMHMM\mpfc_negLL_TR_NR.png', 'Resolution',600);
