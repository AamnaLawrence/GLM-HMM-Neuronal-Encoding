results_5=results_5.results;
fig=figure
% logpTrace_3states=results_3.logpTrace(2:end);
% plot(1:numel(logpTrace_3states), -logpTrace_3states, 'o-','LineWidth',2);
% hold on
% logpTrace_4states=results_4.logpTrace(2:end);
% plot(1:numel(logpTrace_4states), -logpTrace_4states, 'o-','LineWidth',2);
logpTrace_5states=results_5.logpTrace(find(results_5.logpTrace~=0));
logpTrace_5states=logpTrace_5states(2:end);
plot(1:numel(logpTrace_5states), -logpTrace_5states, 'o-','LineWidth',2);
xlabel('Iteration');
ylabel('Negative log-likelihood');
ylim([3.83e5 3.89e5])
title('5 states')
% legend('3 states','4 states','5 states')
manuscriptify(fig,3,4)
exportgraphics(gcf, 'C:\Users\Harris_Lab\OneDrive - Johns Hopkins\Johns Hopkins Neuroscience\Lab\Janak Lab\Neuropixel\Manuscript prep\GLMHMM\logpTrace_mpfc_5states.png', 'Resolution',600);
% fig=figure
% plot([mean(abs(results_3.sqErr(end-10:end))),mean(abs(results_4.sqErr(end-10:end))),mean(abs(results_5.sqErr(end-10:end)))]);
% xticks([1,2,3])
% xticklabels({'3','4','5'})
% xlabel('States')
% ylabel({'Mean squared error', '(last 10 EM iterations)'})
% manuscriptify(fig,'single')
% exportgraphics(gcf, 'C:\Users\Harris_Lab\OneDrive - Johns Hopkins\Johns Hopkins Neuroscience\Lab\Janak Lab\Neuropixel\Manuscript prep\GLMHMM\sqErr_last10.png', 'Resolution',600);

% fig=figure
% plot([mean(abs(diff(results_3.logpTrace(end-10:end)))),mean(abs(diff(results_4.logpTrace(end-10:end)))),mean(abs(diff(results_5.logpTrace(end-10:end))))])
% xticks([1,2,3])
% xticklabels({'3','4','5'})
% xlabel('States')
